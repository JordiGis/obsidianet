# Copy to .env and fill in. Never commit .env.

# ── URLs / ports ──
APP_URL=http://Mac-2.local:3000   # how devices reach the notes app
DOCMOST_PORT=3000                 # user app (login #1)
ADMIN_PORT=8888                   # admin panel (login #2)

# ── Docmost (notes app) ──
APP_SECRET=openssl-rand-hex-32
DB_PASSWORD=openssl-rand-hex-16

# ── Admin panel login (#2) ── separate from the notes app
ADMIN_USER=admin
ADMIN_PASSWORD=openssl-rand-hex-10
ADMIN_JWT_SECRET=openssl-rand-hex-32
