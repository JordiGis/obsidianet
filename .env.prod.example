# Production .env  (copy to .env on the VPS, fill in, never commit)

# ── Domains (point both A records at the VPS IP) ──
NOTES_DOMAIN=notes.example.com
ADMIN_DOMAIN=admin.example.com
ACME_EMAIL=you@example.com          # Let's Encrypt notifications

# ── Public URL of the notes app (HTTPS) ──
APP_URL=https://notes.example.com

# ── Keep app/db ports private (only Caddy is public) ──
BIND_ADDR=127.0.0.1:
COOKIE_SECURE=true

# ── Docmost secrets (generate on the server) ──
APP_SECRET=            # openssl rand -hex 32
DB_PASSWORD=           # openssl rand -hex 16

# ── Admin panel login (#2) ──
ADMIN_USER=admin
ADMIN_PASSWORD=        # openssl rand -hex 12  (or your own strong pass)
ADMIN_JWT_SECRET=      # openssl rand -hex 32

# ── Ports the apps listen on internally (host side, localhost-only) ──
DOCMOST_PORT=3000
ADMIN_PORT=8888
