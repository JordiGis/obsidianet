# ────────────────────────────────────────────────────────────────────────────
# Coolify deployment
# 1. New Resource → Docker Compose (Public Repository)
# 2. Repo: JordiGis/obsidianet  |  Branch: main
# 3. Build Pack: Docker Compose  |  Location: /docker-compose.yml
# 4. Set the env vars below in Coolify UI → Environment
# 5. Assign a public domain → Coolify wires Traefik + HTTPS
# ────────────────────────────────────────────────────────────────────────────

# Required
APP_URL=https://obsidianet.tudominio.com
APP_SECRET=        # openssl rand -hex 32
DB_PASSWORD=       # openssl rand -hex 16

# Optional (defaults shown)
DOCMOST_PORT=3000
