# Copy to .env and fill in. Never commit .env.
# ---- Web UI login ----
OBSIDIAN_USER=admin
OBSIDIAN_PASSWORD=change-me-strong-password

# ---- Ports ----
HTTP_PORT=8080
HTTPS_PORT=8443

# ---- Host user mapping (match `id -u` / `id -g` on the host) ----
PUID=1000
PGID=1000

# ---- Timezone ----
TZ=Europe/Madrid
