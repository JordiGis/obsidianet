# Production .env  (copy to .env on the VPS, fill in, never commit)

# ── Domain (point A record at the VPS IP) ──
NOTES_DOMAIN=notes.example.com
ACME_EMAIL=you@example.com          # Let's Encrypt notifications

# ── Public URL of the app (HTTPS) ──
APP_URL=https://notes.example.com

# ── Keep app/db ports private (only Caddy is public) ──
BIND_ADDR=127.0.0.1:
COOKIE_SECURE=true

# ── Docmost secrets (generate on the server) ──
APP_SECRET=            # openssl rand -hex 32
DB_PASSWORD=           # openssl rand -hex 16

# ── Port the app listens on internally (host side, localhost-only) ──
DOCMOST_PORT=3000
