# Copy to .env and fill in. Never commit .env.

# Host clients use to reach Docmost. Include the port.
# Use the Mac's stable mDNS name so it survives DHCP IP changes.
APP_URL=http://Mac-2.local:3000

# Long random secret (openssl rand -hex 32)
APP_SECRET=replace-with-long-random-hex

# Postgres password (no URL-special chars — use hex)
DB_PASSWORD=replace-with-hex-password

# Published port
PORT=3000
